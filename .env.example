PORT=8000
NODE_ENV=development

# Database configuration
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@db:5432/yougo?schema=public"

# Authentication
JWT_SECRET="super_secret_jwt_key_change_me_in_production"
FRONTEND_URL="http://localhost:3000"

# Email Configuration (Nodemailer via Gmail SMTP)
GMAIL_USER="your_gmail_address@gmail.com"
GMAIL_APP_PASS="your_16_character_gmail_app_password"

# Cloudinary Configuration for profile images (optional)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
